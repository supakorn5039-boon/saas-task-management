#!/usr/bin/env bash
# ════════════════════════════════════════════════════════════════
#  Pre-commit hook — runs only checks that match staged files.
#  Frontend → lint-staged (eslint + prettier on touched files)
#  Backend  → go build / go vet / go test (only if .go files staged)
#  Edit this file freely; it lives in version control.
# ════════════════════════════════════════════════════════════════
set -e

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
pass()  { printf "${GREEN}✓${NC} %s\n" "$1"; }
fail()  { printf "${RED}✗${NC} %s\n" "$1"; }
info()  { printf "${YELLOW}▸${NC} %s\n" "$1"; }

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

STAGED=$(git diff --cached --name-only --diff-filter=ACMR)
FE_FILES=$(echo "$STAGED" | grep -E '^frontend/' || true)
BE_FILES=$(echo "$STAGED" | grep -E '^backend/.*\.go$' || true)

if [ -z "$STAGED" ]; then
  info "No staged files — skipping checks."
  exit 0
fi

# ── Frontend ──────────────────────────────────────────────────
if [ -n "$FE_FILES" ]; then
  info "Frontend changes detected — running lint-staged"
  (cd frontend && npx --no-install lint-staged) || {
    fail "lint-staged failed — fix issues then re-stage."; exit 1;
  }
  pass "frontend lint-staged"
else
  info "No frontend changes — skipping FE checks."
fi

# ── Backend ───────────────────────────────────────────────────
if [ -n "$BE_FILES" ]; then
  info "Backend .go changes detected — running build / vet / test"
  cd backend
  go build ./src/... || { fail "go build failed"; exit 1; }
  pass "go build"
  go vet ./src/...   || { fail "go vet failed";   exit 1; }
  pass "go vet"
  if find ./src -name '*_test.go' -type f | grep -q .; then
    go test ./src/... -count=1 || { fail "go test failed"; exit 1; }
    pass "go test"
  else
    info "no *_test.go files — skipping go test"
  fi
  cd "$REPO_ROOT"
else
  info "No backend changes — skipping BE checks."
fi

pass "Pre-commit checks passed."
